# ---------------------------------------------------------------------------
# Career Relocation Advisor — environment template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# Only DATABASE_URL and JWT_SECRET are strictly required to boot.
# Without LLM_API_KEY the app still works — the narrative summary will be
# null and a deterministic fallback action plan is returned.
# ---------------------------------------------------------------------------

# --- Database (Prisma) -----------------------------------------------------
# Runtime connection string. For Supabase use the POOLED URL (port 6543).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Direct (non-pooled) URL used by Prisma Migrate. For Supabase use the
# direct URL (port 5432). Can be the same as DATABASE_URL for non-pooled
# databases. Recommended — omit only if you know you don't need it.
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# --- Auth (JWT) ------------------------------------------------------------
# Generate a strong secret, e.g. `openssl rand -hex 48`
JWT_SECRET="replace-me-with-a-long-random-string"
# Optional. Defaults to "7d". Accepts ms format: 15m, 24h, 7d, ...
JWT_EXPIRES_IN="7d"

# --- LLM (Gemini) ----------------------------------------------------------
# Get a free key at https://aistudio.google.com
# Leave empty to skip the LLM step (deterministic fallback will be used).
LLM_API_KEY=""
# Optional. Defaults to "gemini-3.1-flash-lite-preview".
LLM_MODEL="gemini-3.1-flash-lite-preview"

# --- Frontend --------------------------------------------------------------
# Base URL the browser uses to reach the API. Defaults to "/api/v1" (same
# origin) — only override this if you proxy the API to a different host.
# NEXT_PUBLIC_API_URL="/api/v1"
